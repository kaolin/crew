#!/usr/bin/env python3
"""crew — a read-only status console + restore map for your hand-run Claude Code sessions.

Feeds off `claude agents --json` (Claude Code >= 2.1.139), which reports every
running session — including the interactive TUIs you started yourself — with cwd,
sessionId, name, and live status (idle / busy / waiting[+waitingFor]).

Subcommands:
  status    glanceable, project-grouped view (default; pure read)
  snapshot  save the current session list as a restore manifest (pure read)
  restore   from a manifest, resume every session in a fresh iTerm2 window
            (DRY-RUN by default — prints what it would do; pass --go to execute)

stdlib only — no pip/conda env needed.
"""
import sys, os, json, time, subprocess, argparse, shutil, re

HOME = os.path.expanduser("~")
SNAP_DIR = os.path.join(HOME, ".crew")
PLIST_LABEL = "com.kaolin.crew-snapshot"

# lower rank = more urgent / sorts first
STATUS_RANK = {"waiting": 0, "busy": 1, "idle": 2, "completed": 3, "stopped": 4, "failed": 5}
STATUS_STYLE = {
    "waiting":   ("33;1", "●"),  # yellow  — needs you
    "busy":      ("36;1", "▶"),  # cyan    — working
    "idle":      ("32",   "○"),  # green   — idle at prompt
    "completed": ("2",    "✓"),
    "stopped":   ("2",    "■"),
    "failed":    ("31;1", "✗"),
}


def c(code, s):
    if not sys.stdout.isatty():
        return s
    return f"\033[{code}m{s}\033[0m"


def _claude_bin():
    """Resolve the claude CLI even under a bare launchd PATH (bash login PATH != zsh)."""
    return (os.environ.get("CREW_CLAUDE")
            or shutil.which("claude")
            or os.path.expanduser("~/.local/bin/claude"))


def load(source=None, include_all=False):
    if source == "-":
        raw = sys.stdin.read()
    elif source:
        with open(source) as f:
            raw = f.read()
    else:
        cmd = [_claude_bin(), "agents", "--json"]
        if include_all:
            cmd.append("--all")
        raw = subprocess.run(cmd, capture_output=True, text=True, check=True).stdout
    return json.loads(raw)


def age(ms):
    if not ms:
        return "?"
    s = max(0, int(time.time() * 1000 - ms) // 1000)
    if s < 60:
        return f"{s}s"
    m, s = divmod(s, 60)
    if m < 60:
        return f"{m}m"
    h, m = divmod(m, 60)
    if h < 24:
        return f"{h}h{m:02d}m"
    d, h = divmod(h, 24)
    return f"{d}d{h}h"


def proj(cwd):
    return os.path.basename((cwd or "").rstrip("/")) or (cwd or "?")


def shq(p):
    return "'" + p.replace("'", "'\\''") + "'"


def cmd_status(a):
    sessions = load(a.source, a.all)
    if not sessions:
        print("no running Claude sessions.")
        return
    groups = {}
    for s in sessions:
        groups.setdefault(s.get("cwd", "?"), []).append(s)
    # order groups by their most-urgent session, then by project name
    order = sorted(
        groups.items(),
        key=lambda kv: (min(STATUS_RANK.get(x.get("status"), 9) for x in kv[1]), proj(kv[0])),
    )
    tally = {}
    for s in sessions:
        tally[s.get("status", "?")] = tally.get(s.get("status", "?"), 0) + 1
    parts = [f"{n} {k}" for k, n in sorted(tally.items(), key=lambda kv: STATUS_RANK.get(kv[0], 9))]
    print(c("1", f"\n  {len(sessions)} sessions") + c("2", "   ·   " + "   ·   ".join(parts)) + "\n")
    for cwd, items in order:
        items.sort(key=lambda x: STATUS_RANK.get(x.get("status"), 9))
        print("  " + c("1", proj(cwd)) + c("2", f"   {cwd}"))
        for s in items:
            st = s.get("status", "?")
            code, glyph = STATUS_STYLE.get(st, ("0", "?"))
            line = (f"    {c(code, glyph)} {c(code, st.ljust(9))} "
                    f"{(s.get('name') or '').ljust(20)} {c('2', age(s.get('startedAt')).rjust(6))}")
            if s.get("waitingFor"):
                line += c("33", f"   ⟵ {s['waitingFor']}")
            print(line)
        print()


def cmd_snapshot(a):
    sessions = load(a.source, include_all=False)
    os.makedirs(SNAP_DIR, exist_ok=True)
    path = a.out or os.path.join(SNAP_DIR, "latest.json")
    spaces = _spaces(a.spaces_source)
    # Record where each window ACTUALLY is (winspace) so restore rebuilds the real
    # layout, incl. untagged sessions; fall back to the tagged home. `spacetag windows`
    # is fetched once and shared. Skip live probes (winspace, launch-flag capture) in
    # test mode (--source given → fixture sessions with non-live pids).
    testmode = bool(a.source)
    wins = _windows() if (spaces and not testmode) else None
    manifest = []
    for s in sessions:
        tty = _tty_of(s.get("pid")) if wins else None
        sp = (_window_space_for_session(s, tty, spaces, wins) if wins else None) \
            or (_space_for_session(s, spaces) if spaces else None)
        manifest.append({
            "cwd": s.get("cwd"), "sessionId": s.get("sessionId"),
            "name": s.get("name"), "status": s.get("status"),
            "launchArgs": [] if testmode else _launch_flags(s.get("pid")),
            "space": sp.get("uuid") if sp else None,
            "spaceIndex": sp.get("index") if sp else None,
            "spaceTag": sp.get("tag") if sp else None,
        })
    # Safety: never let an empty/shrunk read (e.g. the launchd tick firing during
    # shutdown, when sessions are already dying) clobber a good reboot map.
    if not manifest and os.path.exists(path) and not a.force:
        try:
            prev = json.load(open(path))
        except Exception:
            prev = []
        if prev:
            print(f"skip: 0 live sessions — keeping last good map ({len(prev)}) at {path}")
            return
    with open(path, "w") as f:
        json.dump(manifest, f, indent=2)
    if manifest and not a.out:  # keep a timestamped history of good maps
        hist = os.path.join(SNAP_DIR, "history")
        os.makedirs(hist, exist_ok=True)
        with open(os.path.join(hist, f"{int(time.time())}.json"), "w") as f:
            json.dump(manifest, f, indent=2)
    print(f"snapshotted {len(manifest)} sessions → {path}")


def cmd_restore(a):
    path = a.source or os.path.join(SNAP_DIR, "latest.json")
    with open(path) as f:
        manifest = json.load(f)
    print(f"# restore {len(manifest)} sessions from {path}\n")
    launched = 0
    for s in manifest:
        cwd, sid, name = s.get("cwd"), s.get("sessionId"), s.get("name") or ""
        if not cwd or not sid:
            continue
        space = s.get("space")
        where = f"Space {s.get('spaceIndex')} · {s.get('spaceTag')}" if space else "current Space"
        flagstr = "".join(" " + shq(f) for f in (s.get("launchArgs") or []))
        resume = f"cd {shq(cwd)} && claude{flagstr} --resume {sid}"
        if a.go:
            if space:
                subprocess.run([_spacetag_bin(), "goto", str(space)])  # land the new window on its Space
            script = ('tell application "iTerm2"\n'
                      '  create window with default profile\n'
                      '  tell current session of current window\n'
                      f'    set name to "{name}"\n'
                      f'    write text "{resume}"\n'
                      '  end tell\n'
                      'end tell')
            subprocess.run(["osascript", "-e", script], check=False)
            print(f"  ✓ {name.ljust(20)} → {where}")
        else:
            print(f"  would put {name.ljust(20)} → {where}   ({resume})")
        launched += 1
    if not a.go:
        print(f"\n# dry-run: {launched} sessions. re-run with --go to open + place + resume.")


# ---- dispatch: attach to the live iTerm2 session behind a Claude pid ----

def _resolve(sessions, key):
    """Find sessions by exact name, name-prefix, project, then substring."""
    for pred in (
        lambda s: (s.get("name") or "") == key,
        lambda s: (s.get("name") or "").startswith(key),
        lambda s: proj(s.get("cwd")) == key,
        lambda s: key.lower() in ((s.get("name") or "") + " " + (s.get("cwd") or "")).lower(),
    ):
        hit = [s for s in sessions if pred(s)]
        if hit:
            return hit
    return []


def _tty_of(pid):
    if not pid:
        return None
    out = subprocess.run(["ps", "-o", "tty=", "-p", str(pid)], capture_output=True, text=True).stdout.strip()
    return None if not out or out == "??" else "/dev/" + out


def _parse_flags(args):
    """From a `ps args` line ('claude --dangerously-skip-permissions --resume X'),
    return the launch flags worth replaying — minus resume/continue/print/bg, since
    restore re-adds its own --resume."""
    toks = args.split()
    if toks and not toks[0].startswith("-"):
        toks = toks[1:]  # drop the executable (claude / full path)
    drop = {"--resume", "-r", "--continue", "-c", "--fork-session", "--from-pr",
            "--print", "-p", "--bg", "--background"}
    takes_val = {"--resume", "-r", "--from-pr"}
    out, i = [], 0
    while i < len(toks):
        t = toks[i]
        if t in drop:
            i += 2 if (t in takes_val and i + 1 < len(toks) and not toks[i + 1].startswith("-")) else 1
            continue
        out.append(t)
        i += 1
    return out


def _launch_flags(pid):
    """Recover a running claude's launch flags so restore replays --dangerously-skip-permissions, --model, etc."""
    if not pid:
        return []
    args = subprocess.run(["ps", "-ww", "-o", "args=", "-p", str(pid)], capture_output=True, text=True).stdout.strip()
    return _parse_flags(args) if args else []


# AppleScript takes (tty[, msg]) via `on run argv`, so we never string-escape into the script body.
_OSA_PEEK = """on run argv
  set target to item 1 of argv
  tell application "iTerm2"
    repeat with w in windows
      repeat with t in tabs of w
        repeat with s in sessions of t
          if (tty of s) is target then return contents of s
        end repeat
      end repeat
    end repeat
  end tell
  return "__NOTFOUND__"
end run"""

_OSA_TELL = """on run argv
  set target to item 1 of argv
  set msg to item 2 of argv
  tell application "iTerm2"
    repeat with w in windows
      repeat with t in tabs of w
        repeat with s in sessions of t
          if (tty of s) is target then
            tell s to write text msg newline no
            tell s to write text (character id 13) newline no
            return "__OK__"
          end if
        end repeat
      end repeat
    end repeat
  end tell
  return "__NOTFOUND__"
end run"""

_OSA_JUMP = """on run argv
  set target to item 1 of argv
  tell application "iTerm2"
    repeat with w in windows
      repeat with t in tabs of w
        repeat with s in sessions of t
          if (tty of s) is target then
            select s
            tell t to select
            tell w to select
            activate
            return "__OK__"
          end if
        end repeat
      end repeat
    end repeat
  end tell
  return "__NOTFOUND__"
end run"""


def _pick(name):
    sessions = load()
    matches = _resolve(sessions, name)
    if not matches:
        print(f"no running session matches '{name}'")
        return None, None
    if len(matches) > 1:
        print(f"'{name}' is ambiguous — matches:")
        for m in matches:
            print(f"    {m.get('name')}   {proj(m.get('cwd'))}   [{m.get('status')}]")
        return None, None
    s = matches[0]
    tty = _tty_of(s.get("pid"))
    if not tty:
        print(f"couldn't find the tty for {s.get('name')} (pid {s.get('pid')})")
        return None, None
    return s, tty


def _osa(script, *args):
    return subprocess.run(["osascript", "-", *args], input=script, capture_output=True, text=True).stdout


# ---- dispatch adapters: how to peek / tell / jump / read-bounds for a session ----
# Awareness (`claude agents --json`) is terminal-agnostic — it reports every session
# regardless of the terminal it runs in. Only these four verbs are terminal-specific.
# Each adapter maps a live tty to a terminal handle and acts in place. iTerm2 is the
# only backend today; a tmux (or remote-over-ssh) backend drops in by implementing the
# same four methods and teaching `adapter_for()` to route to it — nothing else changes.

class ITerm2Adapter:
    """Drive the live iTerm2 session behind a tty via AppleScript."""
    name = "iTerm2"

    def peek(self, tty):
        """Return the session's on-screen contents, or None if not in this iTerm2."""
        out = _osa(_OSA_PEEK, tty)
        return None if "__NOTFOUND__" in out else out

    def tell(self, tty, msg):
        """Type + submit msg into the session. Returns True on success."""
        return "__OK__" in _osa(_OSA_TELL, tty, msg)

    def jump(self, tty):
        """Front the session's window/tab/pane. Returns True on success."""
        return "__OK__" in _osa(_OSA_JUMP, tty)

    def bounds(self, tty):
        """Return the window's (x, y, w, h) for Space matching, or None."""
        out = _osa(_OSA_BOUNDS, tty).strip()
        if "," not in out or "__NOTFOUND__" in out:
            return None
        try:
            l, t, r, b = [int(float(v)) for v in out.split(",")[:4]]
        except Exception:
            return None
        return (l, t, r - l, b - t)


_ITERM2 = ITerm2Adapter()


class TmuxAdapter:
    """Drive a claude running inside a tmux pane (any socket) via tmux itself.
    Bound to a resolved (socket, target); `adapter_for` builds one per tmux tty."""
    name = "tmux"

    def __init__(self, socket, target):
        self.socket, self.target = socket, target

    def _tmux(self, *args):
        return subprocess.run(["tmux", "-L", self.socket, *args], capture_output=True, text=True)

    def peek(self, tty):
        r = self._tmux("capture-pane", "-t", self.target, "-p")
        return r.stdout if r.returncode == 0 else None

    def tell(self, tty, msg):
        self._tmux("send-keys", "-t", self.target, "-l", msg)   # literal text, then submit
        return self._tmux("send-keys", "-t", self.target, "Enter").returncode == 0

    def jump(self, tty):
        # select the pane within tmux (can't front the attached GUI terminal window)
        self._tmux("select-window", "-t", self.target)
        return self._tmux("select-pane", "-t", self.target).returncode == 0

    def bounds(self, tty):
        return None  # a tmux pane has no window bounds — winspace falls back to tag-map


_TMUX_CACHE = None


def _parse_panes(sock, text):
    out = {}
    for line in text.splitlines():
        if "\t" in line:
            ptty, target = line.split("\t", 1)
            out[ptty] = (sock, target)
    return out


def _tmux_panes():
    """Map every tmux pane's tty -> (socket, target) across all live sockets (cached
    per run). Robust to no tmux, dead/stale sockets, and a bare launchd PATH."""
    global _TMUX_CACHE
    if _TMUX_CACHE is not None:
        return _TMUX_CACHE
    out, tmuxbin = {}, shutil.which("tmux")
    sockdir = os.environ.get("TMUX_TMPDIR") or f"/tmp/tmux-{os.getuid()}"
    if tmuxbin:
        try:
            socks = os.listdir(sockdir)
        except Exception:
            socks = []
        for sock in socks:
            try:
                r = subprocess.run(
                    [tmuxbin, "-L", sock, "list-panes", "-a", "-F",
                     "#{pane_tty}\t#{session_name}:#{window_index}.#{pane_index}"],
                    capture_output=True, text=True)
            except Exception:
                continue
            if r.returncode == 0:
                out.update(_parse_panes(sock, r.stdout))
    _TMUX_CACHE = out
    return out


def _tmux_pane_of(tty):
    return _tmux_panes().get(tty)


def adapter_for(tty):
    """Pick the dispatch backend for a session's tty: a TmuxAdapter when the tty
    belongs to a tmux pane (any socket), else iTerm2."""
    pane = _tmux_pane_of(tty)
    return TmuxAdapter(*pane) if pane else _ITERM2


# ---- spaces: leverage spacetag's CLI to switch to a session's Space ----

def _spacetag_bin():
    env = os.environ.get("CREW_SPACETAG")
    if env:
        return env
    dev = os.path.expanduser(
        "~/dev/spacetag/build/dd/Build/Products/Debug/spacetags-pro.app/Contents/MacOS/spacetags-pro")
    return dev if os.path.exists(dev) else "/Applications/spacetags-pro.app/Contents/MacOS/spacetags-pro"


def _spaces(source=None):
    if source:
        with open(source) as f:
            return json.load(f)
    try:
        return json.loads(subprocess.run([_spacetag_bin(), "dump"], capture_output=True, text=True).stdout)
    except Exception:
        return []


def _norm(s):
    return "".join(ch for ch in (s or "").lower() if ch.isalnum())


def _aliases():
    try:
        return json.load(open(os.path.join(SNAP_DIR, "space_aliases.json")))
    except Exception:
        return {}


def _space_for_session(s, spaces):
    """Map a session to a tagged Space: alias file first, then tag-label match
    (kaolin labels his Spaces by project, so this is usually exact)."""
    cwd = s.get("cwd") or ""
    projn, namen, cwdn = _norm(proj(cwd)), _norm(s.get("name")), _norm(cwd)
    want = _aliases().get(proj(cwd)) or _aliases().get(s.get("name") or "")
    if want is not None:
        for sp in spaces:
            if str(sp.get("index")) == str(want) or sp.get("uuid") == want or _norm(sp.get("tag")) == _norm(str(want)):
                return sp
    for sp in spaces:
        tagn = _norm(sp.get("tag"))
        if not tagn:
            continue
        if (projn and (projn in tagn or tagn in projn)) or (tagn in cwdn) or (namen and tagn in namen):
            return sp
    return None


# ---- winspace: where a session's window ACTUALLY is (bounds match) ----

_OSA_BOUNDS = """on run argv
  set target to item 1 of argv
  tell application "iTerm2"
    repeat with w in windows
      repeat with t in tabs of w
        repeat with s in sessions of t
          if (tty of s) is target then
            set b to bounds of w
            return ((item 1 of b) as string) & "," & ((item 2 of b) as string) & "," & ((item 3 of b) as string) & "," & ((item 4 of b) as string)
          end if
        end repeat
      end repeat
    end repeat
  end tell
  return "__NOTFOUND__"
end run"""


def _windows():
    try:
        return json.loads(subprocess.run([_spacetag_bin(), "windows"], capture_output=True, text=True).stdout)
    except Exception:
        return []


def _tag_for(uuid, spaces):
    for sp in (spaces or []):
        if sp.get("uuid") == uuid:
            return sp.get("tag")
    return None


def _window_space_for_session(s, tty, spaces, wins=None):
    """Where the session's iTerm2 window ACTUALLY is: read its bounds (AppleScript)
    and match against `spacetag windows`. Handles untagged/home sessions, no config.
    Pass `wins` (a prefetched `spacetag windows` list) to avoid refetching per session."""
    if not tty:
        return None
    xywh = adapter_for(tty).bounds(tty)
    if not xywh:
        return None
    x, y, w, h = xywh
    for win in (wins if wins is not None else _windows()):
        if (win.get("owner") or "") != "iTerm" or not win.get("space"):
            continue
        if abs(win["x"] - x) <= 8 and abs(win["y"] - y) <= 8 and abs(win["w"] - w) <= 8 and abs(win["h"] - h) <= 8:
            return {"uuid": win["space"], "index": win.get("spaceIndex"), "tag": _tag_for(win["space"], spaces)}
    return None


# ---- transcript: read a session's conversation from its JSONL (terminal-agnostic) ----

def _jsonl_path(s):
    enc = (s.get("cwd") or "").replace("/", "-")
    return os.path.join(HOME, ".claude", "projects", enc, (s.get("sessionId") or "") + ".jsonl")


def _msg_text(r):
    c = r.get("message", {}).get("content")
    if isinstance(c, str):
        return c
    if isinstance(c, list):
        parts = []
        for b in c:
            if not isinstance(b, dict):
                continue
            if b.get("type") == "text":
                parts.append(b.get("text", ""))
            elif b.get("type") == "tool_use":
                parts.append(f"[{b.get('name', 'tool')}]")
        return "\n".join(p for p in parts if p.strip())
    return ""


def _parse_turns(lines):
    turns = []
    for ln in lines:
        try:
            r = json.loads(ln)
        except Exception:
            continue
        if r.get("type") in ("user", "assistant"):
            t = _msg_text(r).strip()
            if t:
                turns.append((r["type"], t))
    return turns


def _read_turns(s):
    """All (role, text) turns from the session's JSONL, in order. [] if unreadable."""
    try:
        with open(_jsonl_path(s), errors="ignore") as f:
            return _parse_turns(f)
    except Exception:
        return []


def _jsonl_lines(s):
    try:
        with open(_jsonl_path(s), "rb") as f:
            return sum(1 for _ in f)
    except Exception:
        return 0


def _assistant_since(s, before_lines):
    """Assistant messages that appear after line `before_lines` — i.e. the reply to a
    just-sent prompt."""
    out = []
    try:
        with open(_jsonl_path(s), errors="ignore") as f:
            for i, ln in enumerate(f):
                if i < before_lines:
                    continue
                try:
                    r = json.loads(ln)
                except Exception:
                    continue
                if r.get("type") == "assistant":
                    t = _msg_text(r).strip()
                    if t:
                        out.append(t)
    except Exception:
        pass
    return out


def _session_now(sid):
    """Refetch one session's live record from `claude agents --json` (for polling)."""
    try:
        for x in load(include_all=True):
            if x.get("sessionId") == sid:
                return x
    except Exception:
        pass
    return None


_ARTIFACT_RE = re.compile(
    r"https://claude\.ai/[a-z/]*artifacts?/[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}", re.I)


def _artifact_urls(text):
    return _ARTIFACT_RE.findall(text or "")


def cmd_artifacts(a):
    """A gallery of every live artifact URL your fleet has published (from transcripts)."""
    found = False
    for s in load(include_all=a.all):
        seen, urls = set(), []
        try:
            with open(_jsonl_path(s), errors="ignore") as f:
                for ln in f:
                    for u in _artifact_urls(ln):
                        if u not in seen:
                            seen.add(u)
                            urls.append(u)
        except Exception:
            continue
        if not urls:
            continue
        found = True
        print(c("1", f"\n  {s.get('name')}") + c("2", f"  ({proj(s.get('cwd'))})"))
        for u in urls[-a.limit:]:
            print("    " + u)
    print() if found else print("no artifacts found in any live session transcript.")


def cmd_peek(a):
    s, tty = _pick(a.name)
    if not s:
        return
    hdr = c("1", f"{s.get('name')}  [{s.get('status')}]  {proj(s.get('cwd'))}")
    if s.get("waitingFor"):
        hdr += c("33", f"   ⟵ {s['waitingFor']}")
    if a.screen:  # raw terminal scrape — the live TUI (needs a drivable adapter)
        ad = adapter_for(tty)
        out = ad.peek(tty)
        if out is None:
            print(f"{s.get('name')} isn't reachable via {ad.name} (tty {tty}) — different terminal?")
            return
        print(hdr + c("2", f"   {tty}"))
        for ln in out.replace("\r", "\n").rstrip("\n").split("\n")[-a.lines:]:
            print("  " + ln)
        return
    # default: the conversation, from the transcript (fast, works for ANY terminal)
    turns = _read_turns(s)[-a.turns:]
    print(hdr)
    for role, text in turns:
        who = c("36", "you ›") if role == "user" else c("32", "claude ›")
        body = text if len(text) <= 700 else text[:700] + c("2", " …")
        print(f"  {who} {body}\n")
    if not turns:
        print(c("2", "  (no transcript)"))


def cmd_tell(a):
    s, tty = _pick(a.name)
    if not s:
        return
    if s.get("status") == "busy" and not a.force:
        print(f"{s.get('name')} is busy (mid-turn). --force to send anyway (it'll queue).")
        return
    ad = adapter_for(tty)
    ok = ad.tell(tty, a.message)
    print(f"→ sent to {s.get('name')} ({proj(s.get('cwd'))})" if ok
          else f"{s.get('name')} not reachable via {ad.name} (tty {tty})")


def cmd_ask(a):
    """Send a prompt and wait for the reply — a synchronous round-trip to a session."""
    s, tty = _pick(a.name)
    if not s:
        return
    if s.get("status") == "busy" and not a.force:
        print(f"{s.get('name')} is busy (mid-turn). --force to queue behind its current turn.")
        return
    ad = adapter_for(tty)
    before = _jsonl_lines(s)
    if not ad.tell(tty, a.message):
        print(f"couldn't send to {s.get('name')} via {ad.name} (tty {tty})")
        return
    print(c("2", f"→ asked {s.get('name')}; waiting for the reply (Ctrl-C to stop)…"))
    sid = s.get("sessionId")
    deadline = time.time() + a.timeout
    active, quiet, last = False, 0, before
    while time.time() < deadline:
        time.sleep(1.5)
        live = _session_now(sid) or {}
        st, wf = live.get("status"), live.get("waitingFor")
        lines = _jsonl_lines(s)
        if st == "waiting" and wf:
            print(c("33", f"⚠ {s.get('name')} is now waiting on: {wf} — stopping here."))
            break
        if st == "busy" or lines > last:
            active, quiet = True, 0
        elif active and st in ("idle", "waiting", "completed"):
            quiet += 1
            if quiet >= 2:            # settled: idle + no new output for ~3s
                break
        last = lines
    else:
        print(c("33", f"⚠ timed out after {a.timeout}s — reply so far:"))
    replies = _assistant_since(s, before)
    print(c("1", f"\n{s.get('name')} ›"))
    if replies:
        body = "\n".join(replies)
        print("  " + (body if len(body) <= 2000 else body[:2000] + c("2", " …")).replace("\n", "\n  "))
    else:
        print(c("2", "  (no reply captured yet — try `crew peek` in a moment)"))


def cmd_jump(a):
    s, tty = _pick(a.name)
    if not s:
        return
    spaces = _spaces()
    # Prefer where the window ACTUALLY is (winspace); fall back to its tagged home.
    sp = _window_space_for_session(s, tty, spaces) or _space_for_session(s, spaces)
    if sp and sp.get("uuid"):
        subprocess.run([_spacetag_bin(), "goto", str(sp["uuid"])])
    ad = adapter_for(tty)
    ok = ad.jump(tty)
    if sp and sp.get("index"):
        where = f"  (Space {sp['index']}" + (f" · {sp['tag']}" if sp.get("tag") else "") + ")"
    elif sp:
        where = "  (Space set)"
    else:
        where = "  (no Space match — same-Space select only)"
    print(f"jumped to {s.get('name')}{where}" if ok
          else f"{s.get('name')} not reachable via {ad.name} (tty {tty})")


def cmd_where(a):
    s, tty = _pick(a.name)
    if not s:
        return
    spaces = _spaces()
    actual = _window_space_for_session(s, tty, spaces)
    intended = _space_for_session(s, spaces)

    def fmt(sp):
        if not sp:
            return c("2", "—")
        return f"Space {sp.get('index')}" + (f" · {sp['tag']}" if sp.get("tag") else "")

    print(c("1", f"\n  {s.get('name')}   ({proj(s.get('cwd'))})\n"))
    print(f"  actual    (window is on)   {fmt(actual)}")
    print(f"  intended  (tag mapping)    {fmt(intended)}")
    print()


def cmd_goto(a):
    sessions = load(a.source)
    matches = _resolve(sessions, a.name)
    if not matches:
        print(f"no running session matches '{a.name}'")
        return
    if len(matches) > 1:
        print(f"'{a.name}' is ambiguous — matches:")
        for m in matches:
            print(f"    {m.get('name')}   {proj(m.get('cwd'))}   [{m.get('status')}]")
        return
    s = matches[0]
    spaces = _spaces(a.spaces_source)
    if not spaces:
        print("no Spaces from `spacetag dump` — is the pro build present? (set CREW_SPACETAG to override)")
        return
    sp = _space_for_session(s, spaces)
    if not sp:
        print(f"no Space tag matches {s.get('name')} ({proj(s.get('cwd'))}).")
        print(f"add ~/.crew/space_aliases.json, e.g. {{\"{proj(s.get('cwd'))}\": \"<tag, index, or uuid>\"}}")
        return
    print(f"{s.get('name')} → Space {sp.get('index')} · {sp.get('tag')}")
    if a.dry_run:
        return
    subprocess.run([_spacetag_bin(), "goto", str(sp["uuid"])])
    tty = _tty_of(s.get("pid"))
    if tty:
        adapter_for(tty).jump(tty)


# ---- setup / doctor: make crew self-installing (so it packages cleanly) ----

def _plist_xml(crew_path):
    log = os.path.join(SNAP_DIR, "snapshot.log")
    return f'''<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>{PLIST_LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>{crew_path} snapshot</string>
  </array>
  <key>StartInterval</key><integer>300</integer>
  <key>RunAtLoad</key><true/>
  <key>StandardOutPath</key><string>{log}</string>
  <key>StandardErrorPath</key><string>{log}</string>
</dict>
</plist>
'''


def cmd_setup(a):
    self_path = os.path.realpath(__file__)
    link = os.path.expanduser("~/.local/bin/crew")
    plist_path = os.path.expanduser(f"~/Library/LaunchAgents/{PLIST_LABEL}.plist")
    if a.dry_run:
        print(f"would symlink {link} -> {self_path}")
        print(f"would write   {plist_path}  (from this exact path — portable)")
        print(f"would load    {PLIST_LABEL} (snapshot every 300s)")
        return
    os.makedirs(os.path.dirname(link), exist_ok=True)
    if os.path.lexists(link):
        os.remove(link)
    os.symlink(self_path, link)
    print(f"linked  {link} -> {self_path}")
    os.makedirs(os.path.dirname(plist_path), exist_ok=True)
    os.makedirs(SNAP_DIR, exist_ok=True)
    with open(plist_path, "w") as f:
        f.write(_plist_xml(self_path))
    uid = os.getuid()
    subprocess.run(["launchctl", "bootout", f"gui/{uid}/{PLIST_LABEL}"], capture_output=True)
    subprocess.run(["launchctl", "bootstrap", f"gui/{uid}", plist_path], capture_output=True)
    print(f"loaded  {PLIST_LABEL} (snapshot every 300s)\n")
    cmd_doctor(a)


def cmd_doctor(a):
    def check(label, ok, detail=""):
        mark = c("32", "✓") if ok else c("31", "✗")
        print(f"  {mark} {label}" + (f"   {c('2', detail)}" if detail else ""))
    print(c("1", "\n  crew doctor\n"))
    cb = _claude_bin()
    check("claude CLI", bool(shutil.which("claude")) or os.path.exists(cb), cb)
    st = _spacetag_bin()
    st_ok = bool(shutil.which("spacetag")) or os.path.exists(st)
    check("spacetag (optional — Space restore)", st_ok, st if st_ok else "not found; spatial restore off")
    check("iTerm2", os.environ.get("TERM_PROGRAM") == "iTerm.app" or os.path.exists("/Applications/iTerm.app"))
    check("crew on PATH", os.path.lexists(os.path.expanduser("~/.local/bin/crew")))
    uid = os.getuid()
    loaded = subprocess.run(["launchctl", "print", f"gui/{uid}/{PLIST_LABEL}"], capture_output=True).returncode == 0
    check("snapshot agent loaded", loaded, PLIST_LABEL)
    print()


def main():
    ap = argparse.ArgumentParser(prog="crew", description="read-only status + restore for your Claude sessions")
    ap.set_defaults(fn=cmd_status, source=None, all=False, go=False, out=None)
    sub = ap.add_subparsers(dest="cmd")
    ps = sub.add_parser("status", help="project-grouped status view (default)")
    ps.add_argument("--source", help="read JSON from a file or '-' for stdin instead of `claude agents --json`")
    ps.add_argument("--all", action="store_true", help="include completed sessions")
    ps.set_defaults(fn=cmd_status)
    par = sub.add_parser("artifacts", help="gallery of every live artifact URL across your fleet")
    par.add_argument("--all", action="store_true", help="include completed sessions")
    par.add_argument("--limit", type=int, default=5, help="max artifacts per session")
    par.set_defaults(fn=cmd_artifacts)
    pn = sub.add_parser("snapshot", help="save current sessions as a restore manifest")
    pn.add_argument("--source")
    pn.add_argument("--out", help=f"manifest path (default {SNAP_DIR}/latest.json)")
    pn.add_argument("--force", action="store_true", help="write even an empty read (default: keep last good map)")
    pn.add_argument("--spaces-source", dest="spaces_source", help="spaces JSON (testing; default: live `spacetag dump`)")
    pn.set_defaults(fn=cmd_snapshot)
    pr = sub.add_parser("restore", help="resume every session from a manifest into fresh iTerm2 windows")
    pr.add_argument("--source", help=f"manifest path (default {SNAP_DIR}/latest.json)")
    pr.add_argument("--go", action="store_true", help="actually open windows (default: dry-run)")
    pr.set_defaults(fn=cmd_restore)
    pk = sub.add_parser("peek", help="show a session's recent conversation (read-only, any terminal)")
    pk.add_argument("name")
    pk.add_argument("--turns", type=int, default=4, help="recent turns to show (transcript mode)")
    pk.add_argument("--screen", action="store_true", help="raw terminal scrape instead of the transcript")
    pk.add_argument("--lines", type=int, default=40, help="lines to show with --screen")
    pk.set_defaults(fn=cmd_peek)
    pt = sub.add_parser("tell", help="type a prompt into an idle session and submit it (fire-and-forget)")
    pt.add_argument("name")
    pt.add_argument("message")
    pt.add_argument("--force", action="store_true", help="send even if the session is busy")
    pt.set_defaults(fn=cmd_tell)
    pa = sub.add_parser("ask", help="send a prompt and WAIT for the reply (synchronous round-trip)")
    pa.add_argument("name")
    pa.add_argument("message")
    pa.add_argument("--force", action="store_true", help="ask even if the session is busy")
    pa.add_argument("--timeout", type=int, default=300, help="seconds to wait for the reply")
    pa.set_defaults(fn=cmd_ask)
    pj = sub.add_parser("jump", help="switch to a session's Space (via spacetag) and front its window")
    pj.add_argument("name")
    pj.set_defaults(fn=cmd_jump)
    pg = sub.add_parser("goto", help="switch to the Space a session lives on, then front it")
    pg.add_argument("name")
    pg.add_argument("--dry-run", action="store_true", help="print the resolved Space, don't switch")
    pg.add_argument("--source", help="sessions JSON (testing)")
    pg.add_argument("--spaces-source", dest="spaces_source", help="spaces JSON (testing)")
    pg.set_defaults(fn=cmd_goto)
    pw = sub.add_parser("where", help="show where a session's window actually is vs its tagged home")
    pw.add_argument("name")
    pw.set_defaults(fn=cmd_where)
    pu = sub.add_parser("setup", help="symlink crew onto PATH + install the snapshot agent")
    pu.add_argument("--dry-run", action="store_true", help="print what it would do, change nothing")
    pu.set_defaults(fn=cmd_setup)
    ps2 = sub.add_parser("doctor", help="check deps (claude, spacetag, iTerm2, PATH, agent)")
    ps2.set_defaults(fn=cmd_doctor)
    a = ap.parse_args()
    a.fn(a)


if __name__ == "__main__":
    main()
